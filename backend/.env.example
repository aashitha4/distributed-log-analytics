PORT=5000
MONGO_URI=mongodb://localhost:27017/log_analytics
FRONTEND_ORIGIN=http://localhost:5173

MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=raw-logs
SPARK_S3A_ENDPOINT=http://localhost:9000
SPARK_S3A_PATH_STYLE_ACCESS=true

LIVY_URL=
SPARK_MASTER_URL=spark://localhost:7077
SPARK_JOB_MAIN=../spark-jobs/main.py
SPARK_DEPLOY_MODE=client
SPARK_PACKAGES=org.apache.hadoop:hadoop-aws:3.3.4,org.mongodb.spark:mongo-spark-connector_2.12:10.3.0
SPARK_SUBMIT_IN_DOCKER=true
DOCKER_COMPOSE_FILE=docker/docker-compose.yml
DOCKER_CLI=docker
DOCKER_SPARK_SERVICE=spark-master
DOCKER_SPARK_SUBMIT_COMMAND=/opt/spark/bin/spark-submit
DOCKER_SPARK_MASTER_URL=spark://spark-master:7077
DOCKER_SPARK_JOB_MAIN=/opt/spark/jobs/main.py
SPARK_JARS_IVY=/tmp/.ivy2
